<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}NEXUSRDR{% endblock %}</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            /* Light Theme */
            --primary: #0ea5e9;
            --primary-dark: #0284c7;
            --primary-light: #38bdf8;
            --primary-alpha: rgba(14, 165, 233, 0.1);
            --secondary: #6366f1;
            --accent: #8b5cf6;
            
            --success: #10b981;
            --success-bg: rgba(16, 185, 129, 0.1);
            --warning: #f59e0b;
            --warning-dark: #d97706;
            --error: #ef4444;
            --error-dark: #dc2626;
            --error-bg: rgba(239, 68, 68, 0.1);
            --info: #3b82f6;
            --info-bg: rgba(59, 130, 246, 0.1);
            
            --bg-base: #f1f5f9;
            --bg-elevated: #ffffff;
            --bg-muted: #f8fafc;
            --bg-glass: rgba(255, 255, 255, 0.7);
            --bg-glass-hover: rgba(255, 255, 255, 0.85);
            
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            
            --border-color: rgba(15, 23, 42, 0.08);
            --border-glass: rgba(15, 23, 42, 0.12);
            
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.12);
            --shadow-elevated: 0 4px 12px rgba(0, 0, 0, 0.1);
            --shadow-floating: 0 8px 25px rgba(0, 0, 0, 0.15);
            
            --header-height: 80px;
            
            --transition-base: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        [data-theme="dark"] {
            --bg-base: #0f172a;
            --bg-elevated: #1e293b;
            --bg-glass: rgba(30, 41, 59, 0.7);
            --bg-glass-hover: rgba(30, 41, 59, 0.85);
            
            --text-primary: #f8fafc;
            --text-secondary: #cbd5e1;
            --text-muted: #64748b;
            
            --border-color: rgba(248, 250, 252, 0.08);
            --border-glass: rgba(248, 250, 252, 0.12);
            
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);
            --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.5);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg-base);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
            padding-bottom: 160px;
        }

        /* Animated Background Mesh */
        .mesh-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.6;
            filter: blur(80px);
            transition: opacity 0.5s ease;
        }

        .mesh-gradient {
            position: absolute;
            border-radius: 50%;
            filter: blur(40px);
            animation: float 20s ease-in-out infinite;
        }

        .mesh-gradient-1 {
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
            top: -10%;
            left: -10%;
            animation-delay: 0s;
        }

        .mesh-gradient-2 {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, var(--secondary) 0%, transparent 70%);
            top: 50%;
            right: -5%;
            animation-delay: -7s;
        }

        .mesh-gradient-3 {
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
            bottom: -10%;
            left: 30%;
            animation-delay: -14s;
        }

        @keyframes float {
            0%, 100% {
                transform: translate(0, 0) scale(1);
            }
            33% {
                transform: translate(30px, -50px) scale(1.1);
            }
            66% {
                transform: translate(-20px, 30px) scale(0.9);
            }
        }

        /* App Layout */
        .app-container {
            display: flex;
            min-height: 100vh;
            position: relative;
        }
        
        /* ========================================
           HEADER GLASS ULTRA
        ======================================== */
        .app-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--header-height);
            background: var(--bg-glass);
            backdrop-filter: blur(30px) saturate(180%);
            -webkit-backdrop-filter: blur(30px) saturate(180%);
            border-bottom: 1px solid var(--border-glass);
            z-index: 1000;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-base);
        }

        .header-container {
            height: 100%;
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 100%;
        }
        
        .app-logo {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 800;
            font-size: 1.5rem;
            transition: var(--transition-base);
            position: relative;
        }

        .app-footer a {
            color: var(--text-primary);
        }

        .app-footer span,
        .app-footer .text-muted {
            color: inherit !important;
        }

        [data-theme="dark"] .app-footer,
        [data-theme="dark"] .app-footer a,
        [data-theme="dark"] .app-footer span {
            color: #f8fafc;
        }

        [data-theme="light"] .app-footer,
        [data-theme="light"] .app-footer a,
        [data-theme="light"] .app-footer span {
            color: #0f172a;
        }

        .logo-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 1.4rem;
            color: white;
            box-shadow: 0 8px 24px rgba(14, 165, 233, 0.4);
            transition: var(--transition-base);
            position: relative;
            overflow: hidden;
        }

        .logo-icon::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.6s ease;
        }

        .app-logo:hover .logo-icon::before {
            left: 100%;
        }

        .app-logo:hover .logo-icon {
            transform: rotate(360deg) scale(1.05);
            box-shadow: 0 12px 32px rgba(14, 165, 233, 0.5);
        }

        .logo-text {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        /* Header Navigation */
        .header-nav {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex: 1;
            justify-content: center;
            margin: 0 2rem;
        }

        .nav-dropdown {
            position: relative;
        }

        .nav-dropdown-toggle {
            background: var(--bg-glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            padding: 0.625rem 1.25rem;
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.875rem;
            transition: var(--transition-base);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            white-space: nowrap;
        }

        .nav-dropdown-toggle:hover {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
        }

        .nav-dropdown-menu {
            position: absolute;
            top: 100%;
            left: 0;
            min-width: 250px;
            background: var(--bg-elevated);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: var(--transition-base);
            z-index: 1001;
            margin-top: 0.5rem;
        }

        .nav-dropdown:hover .nav-dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .nav-dropdown-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.875rem 1.25rem;
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.875rem;
            transition: var(--transition-base);
            border-bottom: 1px solid var(--border-color);
        }

        .nav-dropdown-item:last-child {
            border-bottom: none;
        }

        .nav-dropdown-item:hover {
            background: var(--bg-glass);
            color: var(--primary);
        }

        .nav-dropdown-item i {
            font-size: 1rem;
            width: 20px;
        }

        /* Header Actions */
        .header-actions {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .header-search {
            position: relative;
            width: 250px;
        }

        .header-search input {
            width: 100%;
            padding: 0.625rem 1rem 0.625rem 2.5rem;
            background: var(--bg-glass);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 0.875rem;
            transition: var(--transition-base);
        }

        .header-search input:focus {
            outline: none;
            border-color: var(--primary);
            background: var(--bg-elevated);
            box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
        }

        .header-search i {
            position: absolute;
            left: 0.875rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .header-search input::placeholder {
            color: var(--text-muted);
        }
        
        .header-btn {
            background: var(--bg-glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            padding: 0.625rem 1.25rem;
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.875rem;
            transition: var(--transition-base);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            white-space: nowrap;
        }

        .header-btn:hover {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
        }

        .header-btn i {
            font-size: 1rem;
        }

        /* Theme Toggle */
        .theme-toggle {
            width: 44px;
            height: 44px;
            background: var(--bg-glass);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition-base);
            color: var(--text-primary);
            font-size: 1.1rem;
        }

        .theme-toggle:hover {
            background: var(--primary);
            color: white;
            transform: rotate(180deg) scale(1.05);
        }

        .mobile-toggle {
            display: none;
            width: 44px;
            height: 44px;
            background: var(--bg-glass);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 1.2rem;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            transition: var(--transition-base);
        }

        .mobile-toggle:hover {
            background: var(--primary);
            color: white;
        }
        
        .mobile-menu-toggle {
            display: none;
            width: 44px;
            height: 44px;
            background: var(--bg-glass);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 1.2rem;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            transition: var(--transition-base);
        }

        .mobile-menu-toggle:hover {
            background: var(--primary);
            color: white;
        }

        .mobile-nav {
            position: fixed;
            top: var(--header-height);
            left: 0;
            right: 0;
            background: var(--bg-elevated);
            border-bottom: 1px solid var(--border-glass);
            box-shadow: var(--shadow-lg);
            transform: translateY(-100%);
            transition: var(--transition-base);
            z-index: 999;
            max-height: calc(100vh - var(--header-height));
            overflow-y: auto;
        }

        .mobile-nav.show {
            transform: translateY(0);
        }

        .mobile-nav-section {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }

        .mobile-nav-title {
            font-size: 0.8rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        .mobile-nav-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.875rem 0;
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition-base);
            border-bottom: 1px solid var(--border-color);
        }

        .mobile-nav-item:last-child {
            border-bottom: none;
        }

        .group-item:hover {
            background: var(--bg-elevated);
            color: var(--primary);
            transform: translateX(4px);
        }

        .group-item i {
            font-size: 1rem;
        }
        
        /* ========================================
           MAIN CONTENT
        ======================================== */
        .app-main {
            flex: 1;
            margin-top: var(--header-height);
            min-height: calc(100vh - var(--header-height));
            transition: margin-left 0.4s ease;
            display: flex;
            flex-direction: column;
            position: relative;
            padding-bottom: 160px;
        }
        
        /* ========================================
           FOOTER
        ======================================== */
        .app-footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--bg-glass);
            backdrop-filter: blur(30px) saturate(180%);
            color: var(--text-primary);
            padding: 1.5rem;
            text-align: center;
            border-top: 1px solid var(--border-glass);
            z-index: 997;
        }
        .app-footer strong {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        /* ========================================
           RESPONSIVE
        ======================================== */
        @media (max-width: 768px) {
            .mobile-menu-toggle {
                display: flex;
            }

            .header-nav {
                display: none;
            }

            .header-container {
                padding: 0 1rem;
            }

            .header-search {
                display: none;
            }

            .header-actions .header-btn span {
                display: none;
            }

            .header-actions .header-btn {
                padding: 0.625rem;
                width: 44px;
                height: 44px;
                justify-content: center;
            }
            .main-content {
                padding: 1rem;
            }
        }

        /* ========================================
           ANIMATIONS
        ======================================== */
        @keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .nav-item,
        .tool-card,
        .tool-group {
            animation: slideInLeft 0.4s ease-out backwards;
        }

        .nav-item:nth-child(1) { animation-delay: 0.05s; }
        .nav-item:nth-child(2) { animation-delay: 0.1s; }
        .nav-item:nth-child(3) { animation-delay: 0.15s; }
        
        .tool-card:nth-child(1),
        .tool-group:nth-child(1) { animation-delay: 0.1s; }
        .tool-card:nth-child(2),
        .tool-group:nth-child(2) { animation-delay: 0.2s; }
        .tool-card:nth-child(3),
        .tool-group:nth-child(3) { animation-delay: 0.3s; }
        .tool-card:nth-child(4),
        .tool-group:nth-child(4) { animation-delay: 0.4s; }
        .tool-card:nth-child(5),
        .tool-group:nth-child(5) { animation-delay: 0.5s; }
    </style>
    
    {% block extra_styles %}{% endblock %}
    
    {% block styles %}{% endblock %}
</head>
<body>
    {% set menu_data = sidebar_menu or {} %}
    {% set top_menu = menu_data.get('top_menu', []) %}
    {% set side_groups = menu_data.get('side_groups', []) %}

    <!-- Animated Background Mesh -->
    <div class="mesh-background">
        <div class="mesh-gradient mesh-gradient-1"></div>
        <div class="mesh-gradient mesh-gradient-2"></div>
        <div class="mesh-gradient mesh-gradient-3"></div>
    </div>

    <div class="app-container">
        <!-- HEADER -->
        <header class="app-header">
            <div class="header-container">

                .header-container {
                    padding: 0 1rem;
                }

                .header-search {
                    display: none;
                }

                .header-actions .header-btn span {
                    display: none;
                }

                .header-actions .header-btn {
                    padding: 0.625rem;
                    width: 44px;
                    height: 44px;
                    justify-content: center;
                }
                .main-content {
                    padding: 1rem;
                }
            }

            /* ========================================
               ANIMATIONS
            ======================================== */
            @keyframes slideInLeft {
                from {
                    opacity: 0;
                    transform: translateX(-30px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            .nav-item,
            .tool-card,
            .tool-group {
                animation: slideInLeft 0.4s ease-out backwards;
            }

            .nav-item:nth-child(1) { animation-delay: 0.05s; }
            .nav-item:nth-child(2) { animation-delay: 0.1s; }
            .nav-item:nth-child(3) { animation-delay: 0.15s; }
            
            .tool-card:nth-child(1),
            .tool-group:nth-child(1) { animation-delay: 0.1s; }
            .tool-card:nth-child(2),
            .tool-group:nth-child(2) { animation-delay: 0.2s; }
            .tool-card:nth-child(3),
            .tool-group:nth-child(3) { animation-delay: 0.3s; }
            .tool-card:nth-child(4),
            .tool-group:nth-child(4) { animation-delay: 0.4s; }
            .tool-card:nth-child(5),
            .tool-group:nth-child(5) { animation-delay: 0.5s; }
        </style>
        
        {% block extra_styles %}{% endblock %}
        
        {% block styles %}{% endblock %}
    </head>
    <body>
        {% set menu_data = sidebar_menu or {} %}
        {% set top_menu = menu_data.get('top_menu', []) %}
        {% set side_groups = menu_data.get('side_groups', []) %}

        <!-- Animated Background Mesh -->
        <div class="mesh-background">
            <div class="mesh-gradient mesh-gradient-1"></div>
            <div class="mesh-gradient mesh-gradient-2"></div>
            <div class="mesh-gradient mesh-gradient-3"></div>
        </div>

        <div class="app-container">
            <!-- HEADER -->
            <header class="app-header">
                <div class="header-container">
                    <a href="/" class="app-logo">
                        <div class="logo-icon">NR</div>
                        <span class="logo-text">NEXUSRDR</span>
                    </a>

                    <!-- Navigation Menu -->
                    <nav class="header-nav">
                        {% if side_groups %}
                            {% for group in side_groups %}
                                {% if group.children %}
                                    <!-- Dropdown for groups with children -->
                                    <div class="nav-dropdown">
                                        <div class="nav-dropdown-toggle">
                                            <i class="bi bi-{{ group.icon or 'grid-3x3-gap' }}"></i>
                                            <span>{{ group.display_name }}</span>
                                            <i class="bi bi-chevron-down"></i>
                                        </div>
                                        <div class="nav-dropdown-menu">
                                            {% for module in group.children %}
                                            <a href="{{ module.url }}" class="nav-dropdown-item">
                                                <i class="bi bi-{{ module.icon or 'gear' }}"></i>
                                                <span>{{ module.display_name }}</span>
                                            </a>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% else %}
                                    <!-- Single tool -->
                                    <a href="{{ group.url }}" class="nav-dropdown-toggle">
                                        <i class="bi bi-{{ group.icon or 'grid-3x3-gap' }}"></i>
                                        <span>{{ group.display_name }}</span>
                                    </a>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </nav>

                    <button class="mobile-menu-toggle" id="mobileMenuToggle" onclick="toggleMobileNav()">
                        <i class="bi bi-list"></i>
                    </button>

                    <div class="header-actions">
                        <div class="header-search">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Buscar ferramentas...">
                        </div>

                        <a href="/blog" class="header-btn">
                            <i class="bi bi-journal-richtext"></i>
                            <span>Blog</span>
                        </a>
                        
                        {% if top_menu %}
                            {% for module in top_menu %}
                            <a href="{{ module.url }}" class="header-btn">
                                <i class="bi bi-{{ module.icon or 'app-indicator' }}"></i>
                                <span>{{ module.display_name }}</span>
                            </a>
                            {% endfor %}
                        {% endif %}

                        <a href="/administrador" class="header-btn">
                            <i class="bi bi-shield-lock"></i>
                            <span>Admin</span>
                        </a>

                        <button class="theme-toggle" id="themeToggle">
                            <i class="bi bi-moon-stars"></i>
                        </button>
                    </div>
                </div>
            </header>

            <!-- Mobile Navigation -->
            <nav class="mobile-nav" id="mobileNav">
                {% if side_groups %}
                    {% for group in side_groups %}
                        <div class="mobile-nav-section">
                            <div class="mobile-nav-title">{{ group.display_name }}</div>
                            {% if group.children %}
                                {% for module in group.children %}
                                <a href="{{ module.url }}" class="mobile-nav-item" {% if 'financeiro' in module.display_name.lower() %}target="_blank" rel="noopener"{% endif %}>
                                    <i class="bi bi-{{ module.icon or 'gear' }}"></i>
                                    <span>{{ module.display_name }}</span>
                                </a>
                                {% endfor %}
                            {% else %}
                                <a href="{{ group.url }}" class="mobile-nav-item">
                                    <i class="bi bi-{{ group.icon or 'grid-3x3-gap' }}"></i>
                                    <span>{{ group.display_name }}</span>
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                {% endif %}

                <div class="mobile-nav-section">
                    <div class="mobile-nav-title">Outros</div>
                    <a href="/blog" class="mobile-nav-item">
                        <i class="bi bi-journal-richtext"></i>
                        <span>Blog</span>
                    </a>
                    <a href="/administrador" class="mobile-nav-item">
                        <i class="bi bi-shield-lock"></i>
                        <span>Admin</span>
                    </a>
                </div>
            </nav>

            <!-- MAIN -->
            <main class="app-main" id="appMain">
                <div class="main-content" id="mainContent">

                    {% block top_banner %}{% endblock %}
                    {% block content %}{% endblock %}
                    {% block bottom_banner %}{% endblock %}
                        {% if group.children %}
                            {% for module in group.children %}
                            <a href="{{ module.url }}" class="mobile-nav-item" {% if 'financeiro' in module.display_name.lower() %}target="_blank" rel="noopener"{% endif %}>
                                <i class="bi bi-{{ module.icon or 'gear' }}"></i>
                                <span>{{ module.display_name }}</span>
                            </a>
                            {% endfor %}
                        {% else %}
                            <a href="{{ group.url }}" class="mobile-nav-item">
                                <i class="bi bi-{{ group.icon or 'grid-3x3-gap' }}"></i>
                                <span>{{ group.display_name }}</span>
                            </a>
                        {% endif %}
                    </div>
                {% endfor %}
            {% endif %}

            <div class="mobile-nav-section">
                <div class="mobile-nav-title">Outros</div>
                <a href="/blog" class="mobile-nav-item">
                    <i class="bi bi-journal-richtext"></i>
                    <span>Blog</span>
                </a>
                <a href="/administrador" class="mobile-nav-item">
                    <i class="bi bi-shield-lock"></i>
                    <span>Admin</span>
                </a>
            </div>
        </nav>

        <!-- MAIN -->
        <main class="app-main" id="appMain">
            <div class="main-content" id="mainContent">

                {% block top_banner %}{% endblock %}
                {% block content %}{% endblock %}
                {% block bottom_banner %}{% endblock %}
            </div>
            
            <!-- FOOTER -->
            <footer class="app-footer">
                <small>
                    <strong>NEXUSRDR</strong> 
                    v3.0.0 | Sistema de Ferramentas Web<br>
                    Desenvolvido por <strong>Rudieri Machado</strong> | 2025
                </small>
                <div class="mt-3 d-flex flex-wrap gap-3 justify-content-center">
                    <a href="/contact" class="text-decoration-none text-muted">Contato</a>
                    <span class="text-muted">â€¢</span>
                    <a href="/privacy" class="text-decoration-none text-muted">PolÃ­tica de Privacidade</a>
                    <span class="text-muted">â€¢</span>
                    <a href="/terms" class="text-decoration-none text-muted">Termos de Uso</a>
                </div>
            </footer>
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Theme Toggle
        const themeToggle = document.getElementById('themeToggle');
        const html = document.documentElement;
        const themeIcon = themeToggle.querySelector('i');

        // Load saved theme
        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-theme', savedTheme);
        updateThemeIcon(savedTheme);

        themeToggle.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        });

        function updateThemeIcon(theme) {
            themeIcon.className = theme === 'light' ? 'bi bi-moon-stars' : 'bi bi-sun';
        }

        // Toggle mobile navigation
        function toggleMobileNav() {
            const mobileNav = document.getElementById('mobileNav');
            const toggle = document.getElementById('mobileMenuToggle');
            const icon = toggle.querySelector('i');
            
            mobileNav.classList.toggle('show');
            
            if (mobileNav.classList.contains('show')) {
                icon.className = 'bi bi-x-lg';
                document.body.style.overflow = 'hidden';
            } else {
                icon.className = 'bi bi-list';
                document.body.style.overflow = '';
            }
        }

        // Close mobile nav on click outside
        document.addEventListener('click', function(e) {
            const mobileNav = document.getElementById('mobileNav');
            const toggle = document.getElementById('mobileMenuToggle');
            
            if (window.innerWidth <= 768 && 
                !mobileNav.contains(e.target) && 
                !toggle.contains(e.target) &&
                mobileNav.classList.contains('show')) {
                toggleMobileNav();
            }
        });

        // Mark active navigation items
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('.nav-dropdown-toggle, .nav-dropdown-item, .mobile-nav-item');
            
            navLinks.forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });

        // Resize handler
        window.addEventListener('resize', function() {
            if (window.innerWidth > 768) {
                const mobileNav = document.getElementById('mobileNav');
                const toggle = document.getElementById('mobileMenuToggle');
                const icon = toggle.querySelector('i');
                
                mobileNav.classList.remove('show');
                icon.className = 'bi bi-list';
                document.body.style.overflow = '';
            }
        });

        console.log(' NEXUSRDR Glass Premium v3 ULTRA loaded!');

        // ========================================
        // NAVEGAÇÃO PARCIAL - SPA-LIKE
        // ========================================
        (function() {
            'use strict';

            const mainContent = document.getElementById('mainContent');
            if (!mainContent) return;

            function isInternalLink(url) {
                try {
                    const urlObj = new URL(url, window.location.origin);
                    return urlObj.origin === window.location.origin;
                } catch {
                    return false;
                }
            }

            function handlePartialNavigation(event) {
                const link = event.currentTarget;
                const url = link.getAttribute('href');
                
                if (!url || !isInternalLink(url) || url.startsWith('#')) {
                    return; // deixa navegaÃ§Ã£o normal
                }

                event.preventDefault();

                // Indicador visual de carregamento
                mainContent.style.opacity = '0.6';
                mainContent.style.pointerEvents = 'none';

                fetch(url)
                    .then(response => {
                        if (!response.ok) throw new Error('Network error');
                        return response.text();
                    })
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const newContent = doc.getElementById('mainContent');
                        
                        if (!newContent) {
                            // Se nÃ£o encontrar mainContent, faz navegaÃ§Ã£o normal
                            window.location.href = url;
                            return;
                        }

                        // Remove estilos antigos da pÃ¡gina anterior
                        removePageStyles();
                        
                        // Adiciona novos estilos da pÃ¡gina
                        addPageStyles(doc);
                        
                        // Substitui apenas o conteÃºdo central
                        mainContent.innerHTML = newContent.innerHTML;
                        
                        // Atualiza URL sem recarregar
                        window.history.pushState({}, '', url);
                        
                        // Atualiza links ativos
                        updateActiveLinks(url);
                        
                        // Scroll para o topo do conteÃºdo
                        mainContent.scrollTop = 0;
                        
                        // Executa scripts do novo conteÃºdo se houver
                        executeScripts(mainContent);
                    })
                    .catch(error => {
                        console.error('Erro na navegaÃ§Ã£o parcial:', error);
                        // Fallback para navegaÃ§Ã£o normal
                        window.location.href = url;
                    })
                    .finally(() => {
                        // Remove indicador de carregamento
                        mainContent.style.opacity = '';
                        mainContent.style.pointerEvents = '';
                    });
            }

            function updateActiveLinks(currentUrl) {
                const currentPath = new URL(currentUrl, window.location.origin).pathname;
                const navLinks = document.querySelectorAll('.nav-link, .group-item, .tool-card');
                
                navLinks.forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href') === currentPath) {
                        link.classList.add('active');
                        
                        // Expande grupo pai se necessÃ¡rio
                        const group = link.closest('.tool-group');
                        if (group) {
                            group.classList.add('expanded');
                        }
                    }
                });
            }

            function removePageStyles() {
                // Remove estilos especÃ­ficos da pÃ¡gina anterior
                const pageStyles = document.querySelectorAll('style[data-page-style]');
                pageStyles.forEach(style => style.remove());
            }

            function addPageStyles(doc) {
                // Adiciona estilos especÃ­ficos da nova pÃ¡gina
                const newStyles = doc.querySelectorAll('style');
                newStyles.forEach(style => {
                    if (style.textContent.trim()) {
                        const newStyleElement = document.createElement('style');
                        newStyleElement.textContent = style.textContent;
                        newStyleElement.setAttribute('data-page-style', 'true');
                        document.head.appendChild(newStyleElement);
                    }
                });
            }

            function executeScripts(container) {
                const scripts = container.querySelectorAll('script');
                scripts.forEach(script => {
                    if (script.src) {
                        // Script externo - cria novo elemento
                        const newScript = document.createElement('script');
                        newScript.src = script.src;
                        document.head.appendChild(newScript);
                    } else {
                        // Script inline - executa
                        try {
                            eval(script.textContent);
                        } catch (e) {
                            console.warn('Erro ao executar script:', e);
                        }
                    }
                });
            }

            function attachPartialNavigation() {
                // Intercepta cliques nos links das ferramentas
                const toolLinks = document.querySelectorAll('.group-item, .tool-card');
                toolLinks.forEach(link => {
                    // Remove listener anterior se existir
                    link.removeEventListener('click', handlePartialNavigation);
                    // Adiciona novo listener
                    link.addEventListener('click', handlePartialNavigation);
                });
            }

            // Inicializa quando DOM estiver pronto
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', attachPartialNavigation);
            } else {
                attachPartialNavigation();
            }

            // Gerencia botÃ£o Voltar/AvanÃ§ar do navegador
            window.addEventListener('popstate', function(event) {
                // Recarrega a pÃ¡gina quando usar botÃµes do navegador
                // Para uma implementaÃ§Ã£o mais avanÃ§ada, poderia fazer fetch da URL atual
                window.location.reload();
            });

            console.log('ðŸš€ NavegaÃ§Ã£o parcial ativada - mÃ³dulos trocam sem recarregar!');
        })();
    </script>
    
    {% block scripts %}{% endblock %}
</body>
</html>